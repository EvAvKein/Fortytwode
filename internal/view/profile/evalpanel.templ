package profile

import (
	"strconv"

	"github.com/EvAvKein/Fortytwode/internal/view/model"
)

// EvalPanel renders a collapsible evaluations section as a card list.
templ EvalPanel(s model.EvalSection) {
	<details>
		<summary>
			<span class="title">
				{ s.Title }
				if s.Private {
					<span class="private" title="Hidden from other viewers">Private</span>
				}
			</span>
			<span class="count">{ strconv.Itoa(s.Count) }</span>
		</summary>
		<div class="body">
			<div class="eval-overview">
				if s.Summary != "" {
					<div class="stat">{ s.Summary }</div>
				}
				if s.Note != "" {
					<span class="sep">·</span>
					<span class="stat-note">{ s.Note }</span>
				}
			</div>
			@EvalList(s.Evals)
		</div>
	</details>
}
