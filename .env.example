# Create a 42 OAuth application at https://profile.intra.42.fr/oauth/applications
# and register the redirect URIs below on it (the running mode picks which applies).

# Required
FT_CLIENT_ID=your_application_uid
FT_CLIENT_SECRET=your_application_secret

# Postgres password for the compose stack (db superuser + the app's connection).
# Set a strong value before the FIRST `make prod`/`make dev` on a host: the postgres
# image only applies it when initialising an empty data volume — an existing
# fortytwode_pgdata volume keeps whatever password it was created with.
POSTGRES_PASSWORD=fortytwode

# Postgres connection string. The compose stack OVERRIDES this to reach Postgres by
# its service name (...@db:5432...); this localhost form is only for running the
# binary directly against the published dev database (keep the password in sync
# with POSTGRES_PASSWORD above). `fetch` does not need it.
DATABASE_URL=postgres://fortytwode:fortytwode@localhost:5432/fortytwode?sslmode=disable

# OAuth redirect URI — MUST exactly match one registered on your 42 app. The compose
# stack sets this per mode, so you normally don't edit it here:
#   make dev   -> http://localhost:8080/api/auth/42/callback   (HTTP-only dev Nginx)
#   make prod  -> https://<your-host>/api/auth/42/callback     (TLS prod Nginx)
#   fetch      -> http://localhost:3000/callback               (the CLI's listener)
# An https:// value also flips the session/job/state cookies to Secure.
FT_REDIRECT_URI=http://localhost:8080/api/auth/42/callback

# Production (HTTPS) deploy — used by `make deploy`. DOMAIN is your real public
# hostname; it's the single source of truth, driving both the prod OAuth redirect
# URI (https://$DOMAIN/...) and the Let's Encrypt certificate. CERTBOT_EMAIL gets
# the expiry/renewal notices. Not needed for `make dev`.
DOMAIN=fortytwode.example.com
CERTBOT_EMAIL=contact@fortytwode.example.com
