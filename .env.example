# Create a 42 OAuth application at https://profile.intra.42.fr/oauth/applications
# and register the redirect URIs below on it (the running mode picks which applies).

# Required
FT_CLIENT_ID=your_application_uid
FT_CLIENT_SECRET=your_application_secret

# Postgres password for the compose stack (db superuser + the app's connection).
# Set a strong value before the FIRST `make prod`/`make dev` on a host: the postgres
# image only applies it when initialising an empty data volume — an existing
# fortytwode_pgdata volume keeps whatever password it was created with.
POSTGRES_PASSWORD=your_postgres_password_here

# Postgres connection string. The compose stack OVERRIDES this to reach Postgres by
# its service name (...@db:5432...); this localhost form is only for running the
# binary directly against the published dev database (keep the password in sync
# with POSTGRES_PASSWORD above). `fetch` does not need it. sslmode=disable is safe
# for Docker bridge / localhost traffic; use sslmode=verify-ca or sslmode=require
# if the database is on a separate host.
DATABASE_URL=postgres://fortytwode:${POSTGRES_PASSWORD}@localhost:5432/fortytwode?sslmode=disable

# OAuth redirect URI — MUST exactly match one registered on your 42 app. The compose
# stack sets this per mode, so you normally don't edit it here:
#   make dev   -> http://localhost:8080/api/v1/auth/42/callback   (HTTP-only dev Nginx)
#   make prod  -> https://<your-host>/api/v1/auth/42/callback     (TLS prod Nginx)
#   fetch      -> http://localhost:3000/callback                  (the CLI's listener)
# An https:// value also flips the session/job/state cookies to Secure.
FT_REDIRECT_URI=http://localhost:8080/api/v1/auth/42/callback

# Production (HTTPS) deploy — used by `make deploy`. DOMAIN is your real public
# hostname; it's the single source of truth, driving both the prod OAuth redirect
# URI (https://$DOMAIN/...) and the Let's Encrypt certificate. CERTBOT_EMAIL gets
# the expiry/renewal notices. Not needed for `make dev`.
DOMAIN=fortytwode.net
CERTBOT_EMAIL=contact@fortytwode.net

# Transactional email (Resend) for sign-up verification links. Create an API key at
# https://resend.com and verify the sending domain (mail.fortytwode.net) by adding the
# DKIM/SPF records it gives you to Cloudflare DNS — on the `mail` subdomain so they don't
# collide with Cloudflare Email Routing's root-domain inbound MX/SPF. Add a DMARC policy
# too: a single `_dmarc` TXT record (edit the one Email Routing may already have added,
# don't create a second); the root policy also covers the mail. subdomain. Start in
# monitor mode — `v=DMARC1; p=none; sp=none; rua=mailto:dmarc@fortytwode.net` — and only
# tighten sp once the rua reports confirm the mail passes and aligns (on DKIM, via a real
# delivering rua mailbox).
#
# When RESEND_API_KEY is empty the app logs the verification link to stderr instead
# of sending (fine for local dev). MAIL_FROM_ADDRESS is the sender mailbox and must
# be on the verified domain; the "Fortytwode" display name is set in code (config.go)
# so this value stays free of spaces/quotes (the shell-source path can't parse those).
# MAIL_REPLY_TO is optional — set it to a Cloudflare-routed inbox so replies reach you.
RESEND_API_KEY=
MAIL_FROM_ADDRESS=no-reply@mail.fortytwode.net
MAIL_REPLY_TO=hello@fortytwode.net
